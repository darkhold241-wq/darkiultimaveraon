<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Escucha continua de "Darki" y captura de comandos -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Llamadas a la API de Claude -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Servicio en segundo plano que nunca se detiene -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Logo flotante que aparece al activarse, por encima de otras apps -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
      Para que AbrirCualquierAppAction encuentre apps por nombre visible
      (ej. "abre COD Mobile") en vez de solo package name exacto. Google
      restringe esto en Play Store salvo justificacion, pero DARKI se
      instala por APK directo (sideload), no aplica esa restriccion.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!--
      Para que Vosk siga escuchando con la pantalla apagada sin que
      Doze/App Standby corte el proceso a los pocos minutos (Xiaomi,
      Realme, Oppo son los mas agresivos). El usuario tiene que aceptar
      el dialogo que esto abre a mano, Android no deja automatizarlo.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--
      Para llamar directo ("llama a mama") y mandar SMS directo
      ("mandale un mensaje a Juan diciendo..."). Sin estos permisos,
      DARKI hace lo mismo pero dejando el numero/mensaje prellenado
      para que el usuario solo toque el boton de enviar/llamar.
    -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!--
      Para cambiar el brillo de pantalla directamente. Es un permiso
      especial: no alcanza con declararlo aca, el usuario lo tiene que
      conceder a mano desde una pantalla especial de Ajustes (ver
      MainActivity, boton "Conceder ajuste de brillo").
    -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!--
      Para cambiar el modo de sonido (silencio/vibrar/normal). Es
      normal (se concede solo al instalar), pero ademas Android pide
      "acceso a No molestar" aparte, que tambien es una pantalla
      especial de Ajustes (ver MainActivity).
    -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <application
        android:name=".DarkiApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_darki_logo"
        android:label="@string/app_name"
        android:theme="@style/Theme.DarkiOS"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DarkiOS">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.DarkiForegroundService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <!--
          Servicio de Accesibilidad: le da a DARKI la capacidad de leer
          la pantalla y controlar el telefono (tocar, escribir, navegar).
          Se activa a mano desde Ajustes > Accesibilidad, Android no
          permite pedirlo con un dialogo de permiso normal.
        -->
        <service
            android:name=".service.DarkiAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice.config"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>
</manifest>
